# Docker Compose — full stack defaults
# Copy to .env in this directory: cp .env.example .env

# Infrastructure
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dsa_studio
POSTGRES_PORT=5432
REDIS_PORT=6379

# Application
WEB_PORT=8080
API_PORT=4000
JWT_SECRET=change-me-in-docker-use-a-long-random-string
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Run prisma db seed on API container start (safe upsert)
SEED_ON_START=true

# Code sandbox: false = run Python/Node inside the API container (default)
# true = spawn sandbox containers (requires Docker socket on the API service)
SANDBOX_USE_DOCKER=false

# AI / chatbot (API container only — never put keys in apps/web)
# LLM_PROVIDER=auto
# auto | openai | anthropic | mock
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_CODE_CHARS=8000

# Rate limits (per user, per hour)
# RATE_LIMIT_USE_REDIS=true
# RATE_LIMIT_CHAT_HOUR=30
# RATE_LIMIT_REVIEW_HOUR=10
# RATE_LIMIT_CLASSIFY_HOUR=20
