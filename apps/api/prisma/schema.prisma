generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LearningLevel {
  beginner
  intermediate
  advanced
}

enum Difficulty {
  basic
  intermediate
  advanced
}

enum AttemptStatus {
  accepted
  wrong_answer
  time_limit
  runtime_error
  incomplete
}

enum ProgressStatus {
  not_attempted
  attempted
  solved
  mastered
}

enum QuestionSource {
  internal
  leetcode
  hackerrank
  codeforces
  interview
  custom
}

enum ImportMethod {
  manual
  csv
  json
  url
}

enum ChatMessageRole {
  user
  assistant
  system
}

enum ChatMessageType {
  query
  hint
  review
}

model User {
  userId               String        @id @default(uuid()) @map("user_id")
  username             String        @unique @db.VarChar(50)
  email                String        @unique @db.VarChar(255)
  passwordHash         String        @map("password_hash") @db.VarChar(255)
  fullName             String?       @map("full_name") @db.VarChar(100)
  avatarUrl            String?       @map("avatar_url")
  learningLevel        LearningLevel @default(beginner) @map("learning_level")
  targetGoal           String?       @map("target_goal")
  dailyTarget          Int           @default(3) @map("daily_target")
  createdAt            DateTime      @default(now()) @map("created_at")
  lastActive           DateTime?     @map("last_active")
  totalQuestionsSolved Int           @default(0) @map("total_questions_solved")
  currentStreak        Int           @default(0) @map("current_streak")
  longestStreak        Int           @default(0) @map("longest_streak")

  attempts         UserAttempt[]
  progress         UserProgress[]
  dailyActivities  DailyActivity[]
  revisionQueue    RevisionQueue[]
  notes            UserNote[]
  customQuestions  CustomQuestion[]
  createdQuestions Question[]       @relation("QuestionCreator")
  createdSolutions Solution[]       @relation("SolutionCreator")
  chatSessions     ChatSession[]
  hintTiers        UserHintTier[]

  @@map("users")
}

model Topic {
  topicId         String     @id @default(uuid()) @map("topic_id")
  topicName       String     @unique @map("topic_name") @db.VarChar(100)
  slug            String     @unique @db.VarChar(100)
  category        String?    @db.VarChar(50)
  description     String?
  difficultyLevel Difficulty @map("difficulty_level")
  prerequisites   Json       @default("[]")
  totalQuestions  Int        @default(0) @map("total_questions")
  iconUrl         String?    @map("icon_url")
  orderIndex      Int?       @map("order_index")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")

  questions    Question[]
  userProgress UserProgress[]

  @@index([category])
  @@index([difficultyLevel])
  @@map("topics")
}

model Question {
  questionId      String         @id @default(uuid()) @map("question_id")
  topicId         String         @map("topic_id")
  title           String         @db.VarChar(255)
  slug            String         @unique @db.VarChar(255)
  description     String
  difficulty      Difficulty
  constraints     String?
  inputFormat     String?        @map("input_format")
  outputFormat    String?        @map("output_format")
  timeComplexity  String?        @map("time_complexity") @db.VarChar(50)
  spaceComplexity String?        @map("space_complexity") @db.VarChar(50)
  hints           Json           @default("[]")
  tags            Json           @default("[]")
  source          QuestionSource @default(internal)
  sourceUrl       String?        @map("source_url")
  isPremium       Boolean        @default(false) @map("is_premium")
  acceptanceRate  Decimal?       @map("acceptance_rate") @db.Decimal(5, 2)
  totalAttempts   Int            @default(0) @map("total_attempts")
  totalSolved     Int            @default(0) @map("total_solved")
  createdById     String?        @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  isActive        Boolean        @default(true) @map("is_active")

  topic           Topic            @relation(fields: [topicId], references: [topicId])
  createdBy       User?            @relation("QuestionCreator", fields: [createdById], references: [userId])
  testCases       TestCase[]
  solutions       Solution[]
  attempts        UserAttempt[]
  progress        UserProgress[]
  revisionQueue   RevisionQueue[]
  notes           UserNote[]
  customQuestions CustomQuestion[]
  chatSessions    ChatSession[]
  hintTiers       UserHintTier[]

  @@index([topicId])
  @@index([difficulty])
  @@index([slug])
  @@map("questions")
}

model TestCase {
  testCaseId     String   @id @default(uuid()) @map("test_case_id")
  questionId     String   @map("question_id")
  input          String
  expectedOutput String   @map("expected_output")
  explanation    String?
  isSample       Boolean  @default(false) @map("is_sample")
  isHidden       Boolean  @default(false) @map("is_hidden")
  orderIndex     Int?     @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@map("test_cases")
}

model Solution {
  solutionId      String   @id @default(uuid()) @map("solution_id")
  questionId      String   @map("question_id")
  language        String   @db.VarChar(30)
  approachName    String?  @map("approach_name") @db.VarChar(100)
  code            String
  explanation     String?
  timeComplexity  String?  @map("time_complexity") @db.VarChar(50)
  spaceComplexity String?  @map("space_complexity") @db.VarChar(50)
  isOptimal       Boolean  @default(false) @map("is_optimal")
  createdById     String?  @map("created_by")
  upvotes         Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  question  Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)
  createdBy User?    @relation("SolutionCreator", fields: [createdById], references: [userId])

  @@map("solutions")
}

model UserAttempt {
  attemptId        String        @id @default(uuid()) @map("attempt_id")
  userId           String        @map("user_id")
  questionId       String        @map("question_id")
  language         String?       @db.VarChar(30)
  submittedCode    String?       @map("submitted_code")
  status           AttemptStatus
  testCasesPassed  Int           @default(0) @map("test_cases_passed")
  totalTestCases   Int?          @map("total_test_cases")
  executionTime    Decimal?      @map("execution_time") @db.Decimal(10, 2)
  memoryUsed       Decimal?      @map("memory_used") @db.Decimal(10, 2)
  attemptedAt      DateTime      @default(now()) @map("attempted_at")
  notes            String?
  isBookmarked     Boolean       @default(false) @map("is_bookmarked")
  difficultyRating Int?          @map("difficulty_rating")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@unique([userId, questionId, attemptedAt])
  @@index([userId, questionId])
  @@index([attemptedAt(sort: Desc)])
  @@map("user_attempts")
}

model UserProgress {
  progressId         String         @id @default(uuid()) @map("progress_id")
  userId             String         @map("user_id")
  questionId         String         @map("question_id")
  topicId            String         @map("topic_id")
  status             ProgressStatus @default(not_attempted)
  firstAttemptDate   DateTime?      @map("first_attempt_date")
  lastAttemptDate    DateTime?      @map("last_attempt_date")
  solvedDate         DateTime?      @map("solved_date")
  totalAttempts      Int            @default(0) @map("total_attempts")
  timeSpentMinutes   Int            @default(0) @map("time_spent_minutes")
  bestExecutionTime  Decimal?       @map("best_execution_time") @db.Decimal(10, 2)
  needRevision       Boolean        @default(false) @map("need_revision")
  nextRevisionDate   DateTime?      @map("next_revision_date")
  revisionCount      Int            @default(0) @map("revision_count")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)
  topic    Topic    @relation(fields: [topicId], references: [topicId])

  @@unique([userId, questionId])
  @@index([userId, status])
  @@index([userId, topicId])
  @@map("user_progress")
}

model DailyActivity {
  activityId         String   @id @default(uuid()) @map("activity_id")
  userId             String   @map("user_id")
  activityDate       DateTime @map("activity_date") @db.Date
  questionsAttempted Int      @default(0) @map("questions_attempted")
  questionsSolved    Int      @default(0) @map("questions_solved")
  timeSpentMinutes   Int      @default(0) @map("time_spent_minutes")
  topicsCovered      Json     @default("[]") @map("topics_covered")
  streakDay          Int?     @map("streak_day")
  dailyGoalMet       Boolean  @default(false) @map("daily_goal_met")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
  @@map("daily_activity")
}

model RevisionQueue {
  queueId       String    @id @default(uuid()) @map("queue_id")
  userId        String    @map("user_id")
  questionId    String    @map("question_id")
  scheduledDate DateTime  @map("scheduled_date") @db.Date
  priority      Int       @default(1)
  reason        String?   @db.VarChar(50)
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@unique([userId, questionId, scheduledDate])
  @@index([userId, scheduledDate])
  @@map("revision_queue")
}

model UserNote {
  noteId     String   @id @default(uuid()) @map("note_id")
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  noteText   String   @map("note_text")
  isPinned   Boolean  @default(false) @map("is_pinned")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@map("user_notes")
}

model CustomQuestion {
  customQuestionId String       @id @default(uuid()) @map("custom_question_id")
  userId           String       @map("user_id")
  questionId       String       @map("question_id")
  sourceName       String?      @map("source_name") @db.VarChar(100)
  sourceUrl        String?      @map("source_url")
  importMethod     ImportMethod @map("import_method")
  originalContent  Json?        @map("original_content")
  createdAt        DateTime     @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@map("custom_questions")
}

model ChatSession {
  sessionId  String   @id @default(uuid()) @map("session_id")
  userId     String   @map("user_id")
  questionId String?  @map("question_id")
  title      String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question?     @relation(fields: [questionId], references: [questionId], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("chat_sessions")
}

model ChatMessage {
  messageId   String          @id @default(uuid()) @map("message_id")
  sessionId   String          @map("session_id")
  role        ChatMessageRole
  content     String
  messageType ChatMessageType @default(query) @map("message_type")
  tokensUsed  Int?            @map("tokens_used")
  createdAt   DateTime        @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model UserHintTier {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  hintTier   Int      @default(0) @map("hint_tier")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [questionId], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_hint_tiers")
}
