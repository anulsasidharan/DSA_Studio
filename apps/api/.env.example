# API server
PORT=4000
NODE_ENV=development

# Database — matches infra/docker/docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dsa_studio

# Cache — matches infra/docker/docker-compose.yml defaults
REDIS_URL=redis://localhost:6379

# Auth (Phase 1)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173

# Code sandbox (Phase 2)
# SANDBOX_USE_DOCKER=true
# SANDBOX_IMAGE_PYTHON=dsa-sandbox-python:latest
# SANDBOX_IMAGE_NODE=dsa-sandbox-node:latest

# AI / LLM (Phase 5)
# LLM_PROVIDER=auto
# auto | openai | anthropic | mock
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_CODE_CHARS=8000

# Rate limits (per user, per hour)
# RATE_LIMIT_USE_REDIS=true
# RATE_LIMIT_CHAT_HOUR=30
# RATE_LIMIT_REVIEW_HOUR=10
# RATE_LIMIT_CLASSIFY_HOUR=20
